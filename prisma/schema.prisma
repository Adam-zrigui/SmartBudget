// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  // optional because OAuth users won’t supply one; we keep it around for
  // potential credential logins later.
  password           String?   // hashed
  emailVerified      DateTime?
  image              String?
  language           String    @default("de") // de or en
  currency           String    @default("EUR")
  taxClass           Int       @default(1)
  state              String    @default("NW")
  
  // Transactions
  transactions       Transaction[]

  // Banking (German banks - finAPI)
  bankAccounts       BankAccount[]
  bankingConsents    BankingConsent[]

  // NextAuth relations
  accounts           Account[]
  sessions           Session[]

  // Budgets
  budgets            Budget[]
  
  // Goals
  savingsGoals       SavingsGoal[]
  
  // Recurring transactions
  recurringTransactions RecurringTransaction[]
  
  // Investments
  investments         Investment[]
  
  // Currencies
  currencies          Currency[]
  
  // User settings
  settings            UserSettings?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Transaction {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type               String    // "income" or "expense"
  amount             Float
  category           String    // Category name from CATEGORIES
  description        String
  date               DateTime
  tag                String?   // "recurring", "annual", etc.
  
  // Recurring transaction relations
  recurringId        String?   // Links to RecurringTransaction that generated this
  recurring          RecurringTransaction? @relation("GeneratedTransactions", fields: [recurringId], references: [id])
  isRecurringTemplate Boolean  @default(false) // This transaction is a template for recurring
  
  // Tax / State Info
  bundesland         String?   // State name (e.g., "Bayern", "Berlin")
  vat                Float?    // Applied VAT rate (19, 7, etc.)
  churchTax          Float?    // Church tax rate if applicable
  applyChurchTax     Boolean   @default(false) // User opt-in for church tax
  municipalTaxRange  String?   // JSON string of min/max municipal tax for reference
  employmentStatus   String?   // "worker", "student", "apprentice" - affects tax treatment
  taxClass           Int?      // German tax class (1-6) for salary calculations
  hasKinder          Boolean   @default(false) // Has dependent children (affects tax)
  
  // Salary allocation (for Gehalt splits)
  salaryAllocation   String?   // JSON string like {"Mieten": 500, "Essen": 300, ...}
  
  // Generated from recurring transactions
  generatedFrom      RecurringTransaction? @relation("GeneratedFromRecurring", fields: [generatedFromId], references: [id])
  generatedFromId    String?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@index([userId])
  @@index([date])
}

model Budget {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  category           String    // Category name
  maxAmount          Float     // Monthly limit
  alertThreshold     Float?    // Alert when spent % of budget (0-100)
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@unique([userId, category])
  @@index([userId])
}

model SavingsGoal {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name               String    // "Urlaub 2026", "Auto", etc.
  targetAmount       Float
  currentAmount      Float     @default(0)
  dueDate            DateTime?
  priority           Int       @default(0) // 0=low, 1=medium, 2=high
  category           String?   // "vacation", "car", "house", "emergency", "retirement"
  description        String?
  isCompleted        Boolean   @default(false)
  
  // Progress tracking
  contributions      GoalContribution[]
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@index([userId])
}

model GoalContribution {
  id                 String    @id @default(cuid())
  goalId             String
  goal               SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  amount             Float
  date               DateTime  @default(now())
  description        String?
  transactionId      String?   // Link to actual transaction if applicable
  
  createdAt          DateTime  @default(now())
  
  @@index([goalId])
}

model RecurringTransaction {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  frequency          String    // "daily", "weekly", "biweekly", "monthly", "quarterly", "yearly"
  interval           Int       @default(1) // Every X periods (e.g., every 2 weeks)
  startDate          DateTime
  endDate            DateTime? // Optional end date
  nextDue            DateTime
  lastProcessed      DateTime?
  
  isActive           Boolean   @default(true)
  autoCreate         Boolean   @default(true) // Automatically create transactions
  
  // Transaction template data
  type               String    // "income" or "expense"
  amount             Float
  category           String
  description        String
  
  // Generated transactions
  transactions       Transaction[] @relation("GeneratedTransactions")
  generatedTransactions Transaction[] @relation("GeneratedFromRecurring")
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@index([userId])
  @@index([nextDue])
  @@index([isActive])
}

model Investment {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name               String    // "Apple Stocks", "Crypto Portfolio", "Real Estate"
  type               String    // "stocks", "crypto", "bonds", "real_estate", "mutual_fund", "etf"
  symbol             String?   // Stock ticker, crypto symbol, etc.
  quantity           Float     // Number of shares/units
  purchasePrice      Float    // Price per unit at purchase
  currentPrice       Float?   // Current market price
  currency           String    @default("EUR")
  
  // Portfolio grouping
  portfolio          String?   // "Conservative", "Aggressive", "Retirement"
  
  // Performance tracking
  purchaseDate       DateTime
  lastUpdated        DateTime?
  totalValue         Float?   // Calculated: quantity * currentPrice
  totalCost          Float?   // Calculated: quantity * purchasePrice
  unrealizedGain     Float?   // Calculated: totalValue - totalCost
  
  // Risk metrics
  riskLevel          String?   // "low", "medium", "high"
  expectedReturn     Float?   // Annual expected return %
  
  // Additional metadata
  broker             String?   // "ING", "Comdirect", "Crypto.com", etc.
  notes              String?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@index([userId])
  @@index([type])
  @@index([portfolio])
}

model Currency {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  code               String    // "USD", "EUR", "GBP", etc.
  name               String    // "US Dollar", "Euro", "British Pound"
  rateToBase         Float     // Exchange rate to base currency
  lastUpdated        DateTime  @default(now())
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@unique([userId, code])
  @@index([userId])
}

model UserSettings {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  baseCurrency       String    @default("EUR")
  theme              String    @default("light") // "light", "dark", "auto"
  language           String    @default("de")
  
  // Notification preferences
  emailNotifications Boolean   @default(true)
  budgetAlerts       Boolean   @default(true)
  goalReminders      Boolean   @default(true)
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model MoneyTip {
  id                 String    @id @default(cuid())
  category           String    // "savings", "tax", "investing", etc.
  language           String    @default("de")
  title              String
  description        String
  impact             String?   // "Sparen pro Monat: €X", etc.
  
  createdAt          DateTime  @default(now())
}

// Banking Integration - German Banks (finAPI)
model BankAccount {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  finapiAccountId    String    // finAPI account ID
  bankName           String    // e.g., "Deutsche Bank"
  accountNumber      String
  iban               String    @unique
  accountType        String    // "checking", "savings", "credit"
  balance            Float     @default(0)
  currency           String    @default("EUR")
  status             String    @default("active") // "active", "inactive", "error"
  lastSync           DateTime?
  
  // OAuth/Token storage
  accessToken        String?
  refreshToken       String?
  tokenExpiresAt     DateTime?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@index([userId])
  @@index([finapiAccountId])
}

model BankingConsent {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  finapiConsentId    String    // finAPI consent ID
  bankName           String
  consentType        String    // "AIS" (Account Info) or "PIS" (Payment Initiation)
  scopes             String[]  // ["accounts", "balances", "transactions", "payments"]
  status             String    @default("active") // "active", "expired", "revoked"
  
  grantedAt          DateTime  @default(now())
  expiresAt          DateTime
  lastUsed           DateTime?
  revokedAt          DateTime?
  
  // Audit trail
  ipAddress          String?
  userAgent          String?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  @@index([userId])
  @@index([finapiConsentId])
}

// NextAuth models required by Prisma adapter
model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @map("refresh_token")
  access_token       String?  @map("access_token")
  expires_at         Int?     @map("expires_at")
  token_type         String?  @map("token_type")
  scope              String?
  id_token           String?  @map("id_token")
  session_state      String?

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
